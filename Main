import pygame
import sys
import math

from Classes import (
    Particle,
    set_particles,
    reset_particles,
    update_particles,
    throw,
    ELECTROSTATIC_CONSTANT
)

pygame.init()

WIDTH, HEIGHT = 800, 600
screen = pygame.display.set_mode((WIDTH, HEIGHT))
pygame.display.set_caption("Particle Simulator")

clock = pygame.time.Clock()

BLACK = (0, 0, 0)
RED = (255, 0, 0)
BLUE = (0, 0, 255)
GRAY = (150, 150, 150)
WHITE = (255, 255, 255)

particles = []
set_particles(particles)

current_type = "proton"
current_color = RED
current_charge = 1
current_mass = 1
current_radius = 4

throw_mode = False

running = True
while running:
    clock.tick(90)

    screen.fill(BLACK)

    font = pygame.font.SysFont(None, 24)
    text = "THROW MODE: ON" if throw_mode else "THROW MODE: OFF"
    screen.blit(font.render(text, True, WHITE), (10, 10))

    for event in pygame.event.get():

        if event.type == pygame.QUIT:
            running = False

        elif event.type == pygame.KEYDOWN:

            if event.key == pygame.K_p:
                current_type = "proton"
                current_color = RED
                current_charge = 1
                current_mass = 1
                current_radius = 4

            elif event.key == pygame.K_e:
                current_type = "electron"
                current_color = BLUE
                current_charge = -1
                current_mass = 0.05
                current_radius = 1

            elif event.key == pygame.K_n:
                current_type = "neutron"
                current_color = GRAY
                current_charge = 0
                current_mass = 1
                current_radius = 4

            elif event.key == pygame.K_r:
                reset_particles()

            elif event.key == pygame.K_q:
                throw_mode = not throw_mode

        elif event.type == pygame.MOUSEBUTTONDOWN:

            if event.button == 1:

                if throw_mode:

                    if particles:
                        throw(particles[-1])

                else:

                    x, y = event.pos

                    dx = 0
                    dy = 0

                    if current_type == "electron":

                        nearest_proton = None
                        nearest_dist = float("inf")

                        for p in particles:

                            if p.type == "proton":

                                d = math.hypot(x - p.x, y - p.y)

                                if d < nearest_dist:
                                    nearest_dist = d
                                    nearest_proton = p

                        if nearest_proton and 10 < nearest_dist < 200:

                            dxp = x - nearest_proton.x
                            dyp = y - nearest_proton.y

                            dist = math.hypot(dxp, dyp)

                            dir_x = dxp / dist
                            dir_y = dyp / dist

                            tan_x = -dir_y
                            tan_y = dir_x

                            speed = math.sqrt(
                                abs(
                                    ELECTROSTATIC_CONSTANT
                                    * current_charge
                                    * nearest_proton.charge
                                )
                                / (current_mass * dist)
                            )

                            speed *= 0.5

                            dx = tan_x * speed
                            dy = tan_y * speed

                    particles.append(
                        Particle(
                            x,
                            y,
                            dx,
                            dy,
                            current_radius,
                            current_color,
                            current_type,
                            current_charge,
                            current_mass
                        )
                    )

    update_particles()

    for p in particles:
        p.draw(screen)

    pygame.display.flip()

pygame.quit()
sys.exit()