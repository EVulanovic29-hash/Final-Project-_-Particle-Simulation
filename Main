import pygame
import sys
import math
import copy

from Classes import (
    Particle,
    set_particles,
    reset_particles,
    update_particles,
    throw,
    ELECTROSTATIC_CONSTANT
)

pygame.init()

WIDTH, HEIGHT = 800, 600
screen = pygame.display.set_mode((WIDTH, HEIGHT))
pygame.display.set_caption("Particle Simulator")

clock = pygame.time.Clock()

BLACK = (0, 0, 0)
RED = (255, 0, 0)
BLUE = (0, 0, 255)
GRAY = (150, 150, 150)
WHITE = (255, 255, 255)

particles = []
set_particles(particles)

history = []
history_index = -1

current_type = "proton"
current_color = RED
current_charge = 1
current_mass = 1
current_radius = 4

throw_mode = False
paused = False
time_control = False

hold_back = False
hold_forward = False

time_speed = 1

running = True


def save_state():
    global history, history_index

    state = copy.deepcopy(particles)

    history = history[:history_index + 1]
    history.append(state)

    history_index += 1


def load_state(i):
    global particles

    particles.clear()

    for p in copy.deepcopy(history[i]):
        particles.append(p)


def simulate_forward(steps):
    global particles

    snapshot = copy.deepcopy(particles)

    for _ in range(steps):
        update_particles()

    return copy.deepcopy(particles)


save_state()

while running:

    clock.tick(90)

    screen.fill(BLACK)

    font = pygame.font.SysFont(None, 24)

    text = (
        f"THROW:{'ON' if throw_mode else 'OFF'} | "
        f"{'PAUSED' if paused else 'RUN'} | "
        f"TIME:{'ON' if time_control else 'OFF'} | "
        f"SPEED:{time_speed}"
    )

    screen.blit(font.render(text, True, WHITE), (10, 10))

    for event in pygame.event.get():

        if event.type == pygame.QUIT:
            running = False

        elif event.type == pygame.KEYDOWN:

            if event.key == pygame.K_p:
                current_type = "proton"
                current_color = RED
                current_charge = 1
                current_mass = 1
                current_radius = 4

            elif event.key == pygame.K_e:
                current_type = "electron"
                current_color = BLUE
                current_charge = -1
                current_mass = 0.05
                current_radius = 1

            elif event.key == pygame.K_n:
                current_type = "neutron"
                current_color = GRAY
                current_charge = 0
                current_mass = 1
                current_radius = 4

            elif event.key == pygame.K_r:
                reset_particles()
                history.clear()
                history_index = -1
                save_state()

            elif event.key == pygame.K_q:
                throw_mode = not throw_mode

            elif event.key == pygame.K_SPACE:
                paused = not paused

            elif event.key == pygame.K_t:
                time_control = not time_control

            elif event.key == pygame.K_g:
                if time_control:
                    hold_back = True

            elif event.key == pygame.K_h:
                if time_control:
                    hold_forward = True

            elif event.key == pygame.K_UP:
                if time_control:
                    time_speed += 1

            elif event.key == pygame.K_DOWN:
                if time_control:
                    time_speed = max(1, time_speed - 1)

        elif event.type == pygame.KEYUP:

            if event.key == pygame.K_g:
                hold_back = False

            elif event.key == pygame.K_h:
                hold_forward = False

        elif event.type == pygame.MOUSEBUTTONDOWN:

            if event.button == 1:

                if throw_mode and particles:
                    throw(particles[-1])
                    save_state()

                else:

                    x, y = event.pos

                    dx = 0
                    dy = 0

                    if current_type == "electron":

                        nearest = None
                        best = float("inf")

                        for p in particles:
                            if p.type == "proton":
                                d = math.hypot(x - p.x, y - p.y)
                                if d < best:
                                    best = d
                                    nearest = p

                        if nearest and 10 < best < 200:

                            dxp = x - nearest.x
                            dyp = y - nearest.y

                            dist = math.hypot(dxp, dyp)

                            tx = -dyp / dist
                            ty = dxp / dist

                            speed = math.sqrt(
                                abs(ELECTROSTATIC_CONSTANT *
                                    current_charge *
                                    nearest.charge)
                                / (current_mass * dist)
                            ) * 0.5

                            dx = tx * speed
                            dy = ty * speed

                    particles.append(
                        Particle(
                            x, y, dx, dy,
                            current_radius,
                            current_color,
                            current_type,
                            current_charge,
                            current_mass
                        )
                    )

                    save_state()

    # TIME CONTROL SYSTEM

    if time_control:

        if hold_back:

            for _ in range(time_speed):
                if history_index > 0:
                    history_index -= 1
                    load_state(history_index)

        if hold_forward:

            for _ in range(time_speed):

                if history_index < len(history) - 1:

                    history_index += 1
                    load_state(history_index)

                else:
                    particles = simulate_forward(time_speed)
                    save_state()

    elif not paused:

        update_particles()
        save_state()

    for p in particles:
        p.draw(screen)

    pygame.display.flip()

pygame.quit()
sys.exit()