# main.py

import pygame
import sys
import math
import copy

from Classes import (
    Particle,
    set_particles,
    reset_particles,
    update_particles,
    throw,
    ELECTROSTATIC_CONSTANT
)

pygame.init()

WIDTH, HEIGHT = 800, 600

screen = pygame.display.set_mode((WIDTH, HEIGHT))
pygame.display.set_caption("Particle Simulator")

clock = pygame.time.Clock()

BLACK = (0, 0, 0)
RED = (255, 0, 0)
BLUE = (0, 0, 255)
GRAY = (150, 150, 150)
WHITE = (255, 255, 255)

particles = []
set_particles(particles)

# Time history system
history = []
history_index = -1

# Current particle settings
current_type = "proton"
current_color = RED
current_charge = 1
current_mass = 1
current_radius = 4

# Simulation controls
throw_mode = False
paused = False
time_control = False

hold_back = False
hold_forward = False

time_speed = 1
simulation_speed = 1.0

running = True


# Save current simulation state
def save_state():

    global history
    global history_index

    state = copy.deepcopy(particles)

    history = history[:history_index + 1]

    history.append(state)

    history_index += 1


# Load a previous saved state
def load_state(i):

    particles.clear()

    for p in copy.deepcopy(history[i]):
        particles.append(p)


save_state()

while running:

    clock.tick(90)

    screen.fill(BLACK)

    font = pygame.font.SysFont(None, 24)

    # UI text
    text = (
        f"THROW:{'ON' if throw_mode else 'OFF'} | "
        f"{'PAUSED' if paused else 'RUN'} | "
        f"TIME:{'ON' if time_control else 'OFF'} | "
        f"SCRUB:{time_speed} | "
        f"SIM:{simulation_speed:.1f}x | "
        f"Particle Count: {len(particles)}"
    )

    screen.blit(font.render(text, True, WHITE), (10, 10))

    for event in pygame.event.get():

        if event.type == pygame.QUIT:
            running = False

        elif event.type == pygame.KEYDOWN:

            # Proton select
            if event.key == pygame.K_p:

                current_type = "proton"
                current_color = RED
                current_charge = 1
                current_mass = 1
                current_radius = 4

            # Electron select
            elif event.key == pygame.K_e:

                current_type = "electron"
                current_color = BLUE
                current_charge = -1
                current_mass = 0.02
                current_radius = 1

            # Neutron select
            elif event.key == pygame.K_n:

                current_type = "neutron"
                current_color = GRAY
                current_charge = 0
                current_mass = 1
                current_radius = 4

            # Reset simulation
            elif event.key == pygame.K_r:

                reset_particles()

                history.clear()
                history_index = -1

                save_state()

            # Toggle throw mode
            elif event.key == pygame.K_q:

                throw_mode = not throw_mode

            # Pause simulation
            elif event.key == pygame.K_SPACE:

                paused = not paused

            # Toggle time control mode
            elif event.key == pygame.K_t:

                time_control = not time_control

                if not time_control:
                    history_index = len(history) - 1

            # Hold rewind
            elif event.key == pygame.K_g:

                if time_control:
                    hold_back = True

            # Hold fast-forward
            elif event.key == pygame.K_h:

                if time_control:
                    hold_forward = True

            # Increase scrub speed
            elif event.key == pygame.K_UP:

                if time_control:
                    time_speed += 1

            # Decrease scrub speed
            elif event.key == pygame.K_DOWN:

                if time_control:
                    time_speed = max(1, time_speed - 1)

            # Increase simulation speed
            elif event.key == pygame.K_RIGHT:

                keys = pygame.key.get_pressed()

                speed_step = 0.1

                if keys[pygame.K_LSHIFT] or keys[pygame.K_RSHIFT]:
                    speed_step = 1.0

                simulation_speed = round(
                    simulation_speed + speed_step,
                    1
                )

            # Decrease simulation speed
            elif event.key == pygame.K_LEFT:

                keys = pygame.key.get_pressed()

                speed_step = 0.1

                if keys[pygame.K_LSHIFT] or keys[pygame.K_RSHIFT]:
                    speed_step = 1.0

                simulation_speed = max(
                    0.1,
                    round(simulation_speed - speed_step, 1)
                )

        elif event.type == pygame.KEYUP:

            if event.key == pygame.K_g:
                hold_back = False

            elif event.key == pygame.K_h:
                hold_forward = False

        elif event.type == pygame.MOUSEBUTTONDOWN:

            if event.button == 1:

                # Throw latest particle
                if throw_mode and particles:

                    throw(particles[-1])

                    save_state()

                else:

                    x, y = event.pos

                    dx = 0
                    dy = 0

                    # Electron orbit setup
                    if current_type == "electron":

                        nearest = None
                        best = float("inf")

                        for p in particles:

                            if p.type == "proton":

                                d = math.hypot(
                                    x - p.x,
                                    y - p.y
                                )

                                if d < best:

                                    best = d
                                    nearest = p

                        if nearest and best < 300:

                            dxp = x - nearest.x
                            dyp = y - nearest.y

                            dist = math.hypot(
                                dxp,
                                dyp
                            )

                            # Radial direction
                            nx = dxp / dist
                            ny = dyp / dist

                            # Tangential direction
                            tx = -ny
                            ty = nx

                            # Circular orbit equation
                            orbital_speed = math.sqrt(
                                (
                                    abs(
                                        ELECTROSTATIC_CONSTANT
                                    )
                                    *
                                    abs(current_charge)
                                    *
                                    abs(nearest.charge)
                                )
                                /
                                (
                                    current_mass
                                    * dist
                                )
                            )

                            dx = tx * orbital_speed
                            dy = ty * orbital_speed

                            # Inherit nucleus motion
                            dx += nearest.dx
                            dy += nearest.dy

                    # Create particle
                    particles.append(
                        Particle(
                            x,
                            y,
                            dx,
                            dy,
                            current_radius,
                            current_color,
                            current_type,
                            current_charge,
                            current_mass
                        )
                    )

                    save_state()

    # Time control system
    if time_control:

        if hold_back:

            for _ in range(time_speed):

                if history_index > 0:

                    history_index -= 1
                    load_state(history_index)

        if hold_forward:

            for _ in range(time_speed):

                if history_index < len(history) - 1:

                    history_index += 1
                    load_state(history_index)

    else:

        if not paused:

            # Faster than realtime
            if simulation_speed >= 1:

                for _ in range(int(simulation_speed)):

                    update_particles()
                    save_state()

            # Slower than realtime
            else:

                slow_factor = int(
                    round(1 / simulation_speed)
                )

                if pygame.time.get_ticks() % slow_factor == 0:

                    update_particles()
                    save_state()

            history_index = len(history) - 1

    # Draw particles
    for p in particles:
        p.draw(screen)

    pygame.display.flip()

pygame.quit()
sys.exit()